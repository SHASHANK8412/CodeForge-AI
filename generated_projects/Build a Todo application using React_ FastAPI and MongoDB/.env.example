# ==============================================================================
# AIForge Generated Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Server configuration
PORT=8000
HOST=0.0.0.0

# Database URL Connection String
DATABASE_URL=mongodb://admin:secure_password@localhost:27017/app_database?authSource=admin

# Authentication details
JWT_SECRET=super_secret_session_jwt_key_please_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External AI Model Integrations
OPENAI_API_KEY=your-openai-api-key-here
OLLAMA_MODEL=qwen2.5-coder:latest
OLLAMA_BASE_URL=http://localhost:11434

# Debug settings
DEBUG=True
